# =============================================================================
# 勤怠管理システム 環境変数サンプル
# 本ファイルをコピーして .env を作成し、実際の値を設定してください
#   cp .env.example .env
# =============================================================================

# ---- App ----
APP_ENV=development            # development | production
TZ=Asia/Tokyo
LOG_LEVEL=INFO

# ---- Backend ----
BACKEND_PORT=8000
# JWT 署名キー（本番は openssl rand -hex 32 等で生成した長いランダム文字列に）
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14

# CORS 許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost,http://localhost:8080

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=attendance
POSTGRES_USER=attendance_app
POSTGRES_PASSWORD=change-me
# SQLAlchemy 用 URL（通常は上の値から backend で組み立てる）
DATABASE_URL=postgresql+psycopg://attendance_app:change-me@postgres:5432/attendance

# ---- Frontend ----
FRONTEND_PORT=5173
VITE_API_BASE_URL=/api

# ---- Nginx (外部公開ポート) ----
NGINX_PORT=8080

# ---- SMTP (通知メール) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.local
SMTP_USE_TLS=true

# ---- Cloudflare Tunnel (Phase 8 で使用) ----
# Zero Trust ダッシュボードで発行したトークン
CLOUDFLARE_TUNNEL_TOKEN=
